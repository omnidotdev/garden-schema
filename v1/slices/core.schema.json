{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://garden.omni.dev/v1/slices/core.schema.json",
  "title": "Core Slice",
  "description": "Core garden identity and metadata",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Garden name"
    },
    "description": {
      "type": "string",
      "description": "Garden description"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Last updated timestamp"
    }
  },
  "required": ["name"],
  "additionalProperties": false
}
